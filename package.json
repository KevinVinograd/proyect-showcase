{
  "name": "kevin-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "build:client": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "qa:visual": "node tools/puppeteer/runner.mjs",
    "qa:visual:keep": "node tools/puppeteer/runner.mjs --keep",
    "qa:visual:mobile": "node tools/puppeteer/runner.mjs --mobile",
    "qa:visual:grid": "node tools/puppeteer/runner.mjs --suite layout",
    "qa:visual:clean": "node tools/puppeteer/runner.mjs --clean",
    "qa:gate": "node tools/puppeteer/gate.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "^9.5.0",
    "@shadergradient/react": "^2.4.20",
    "camera-controls": "^3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lucide-react": "^1.7.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
